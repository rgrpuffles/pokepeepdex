{
  "name": "pokepeepdex",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate:cards-manifest": "node scripts/generate-cards-manifest.mjs",
    "prebuild": "pnpm generate:cards-manifest",
    "predeploy": "pnpm generate:cards-manifest",
    "prestart": "pnpm generate:cards-manifest",
    "start": "ng serve",
    "build": "ng build",
    "deploy": "ng deploy --base-href /pokepeepdex/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:pokepeepdex": "node dist/pokepeepdex/server/server.mjs"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-cli-ghpages": "^3.1.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
